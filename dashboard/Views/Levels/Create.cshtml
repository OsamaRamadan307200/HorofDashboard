@model HorofDashboard.ViewModels.LevelCreateViewModel

@{
    ViewData["Title"] = "Create Level";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">Create New Level</h4>
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Back to List
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label">Name *</label>
                                    <input asp-for="Name" class="form-control" placeholder="Enter level name" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Url" class="form-label">URL *</label>
                                    <input asp-for="Url" class="form-control" placeholder="/levels/level-name" />
                                    <span asp-validation-for="Url" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter level description"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Position" class="form-label">Position</label>
                                    <input asp-for="Position" class="form-control" type="number" min="1" />
                                    <span asp-validation-for="Position" class="text-danger"></span>
                                    <div class="form-text">Leave empty to auto-assign next position</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <div class="form-check mt-4">
                                        <input asp-for="Status" class="form-check-input" type="checkbox" />
                                        <label asp-for="Status" class="form-check-label">Active Status</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Icon Image</label>
                            <input type="file" name="iconFile" class="form-control" accept="image/*" />
                            <div class="form-text">Upload an icon image for this level</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Pic_Icon" class="form-label">Or Icon Path</label>
                            <input asp-for="Pic_Icon" class="form-control" placeholder="/images/icon.png" />
                            <span asp-validation-for="Pic_Icon" class="text-danger"></span>
                            <div class="form-text">Alternatively, provide a direct path to the icon</div>
                        </div>

                        <div class="d-flex gap-2 pt-3">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save me-2"></i>Create Level
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
