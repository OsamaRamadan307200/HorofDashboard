@model HorofDashboard.Models.Level

@{
    ViewData["Title"] = "Delete Level";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-exclamation-triangle me-2"></i>Delete Level
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <strong>Warning!</strong> Are you sure you want to delete this level? This action cannot be undone.
                    </div>

                    <div class="text-center mb-4">
                        @if (!string.IsNullOrEmpty(Model.PicIcon))
                        {
                            <img src="@Model.PicIcon" alt="@Model.Name" class="rounded shadow mb-3" style="max-width: 100px;">
                        }
                        <h5>@Model.Name</h5>
                        <p class="text-muted">@Model.Description</p>
                    </div>

                    <div class="row text-center mb-4">
                        <div class="col-4">
                            <div class="card bg-light">
                                <div class="card-body py-2">
                                    <div class="h5 mb-0">@Model.Position</div>
                                    <small class="text-muted">Position</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="card bg-light">
                                <div class="card-body py-2">
                                    <div class="h5 mb-0">@Model.Units.Count</div>
                                    <small class="text-muted">Units</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="card bg-light">
                                <div class="card-body py-2">
                                    <div class="h5 mb-0">
                                        <span class="badge @(Model.Status ? "bg-success" : "bg-secondary")">
                                            @(Model.Status ? "Active" : "Inactive")
                                        </span>
                                    </div>
                                    <small class="text-muted">Status</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (Model.Units.Any())
                    {
                        <div class="alert alert-danger">
                            <strong>Important:</strong> This level has @Model.Units.Count associated unit(s).
                            Deleting this level will also affect these units.
                        </div>
                    }

                    <form asp-action="Delete" method="post">
                        <input asp-for="Id" type="hidden" />
                        <div class="d-flex gap-2 justify-content-center">
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash me-2"></i>Yes, Delete Level
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>