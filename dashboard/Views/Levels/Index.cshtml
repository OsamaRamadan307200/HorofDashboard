@model IEnumerable<HorofDashboard.Models.Level>

@{
    ViewData["Title"] = "Level Management";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h2 mb-1">Level Management</h1>
                    <p class="text-muted mb-0">Manage course levels and their properties</p>
                </div>
              @*   <a href="@Url.Action("Create")" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Add New Level
                </a> *@
            </div>
        </div>
    </div>

    <!-- Success/Error Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h3 class="mb-0">@Model.Count()</h3>
                            <p class="mb-0">Total Levels</p>
                        </div>
                        <i class="fas fa-layer-group fa-2x opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h3 class="mb-0">@Model.Count(l => l.Status)</h3>
                            <p class="mb-0">Active Levels</p>
                        </div>
                        <i class="fas fa-eye fa-2x opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-danger text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h3 class="mb-0">@Model.Count(l => !l.Status)</h3>
                            <p class="mb-0">Inactive Levels</p>
                        </div>
                        <i class="fas fa-eye-slash fa-2x opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h3 class="mb-0">@Model.Sum(l => l.Units.Count)</h3>
                            <p class="mb-0">Total Units</p>
                        </div>
                        <i class="fas fa-book fa-2x opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Levels Table -->
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover" id="levelsTable">
                    <thead class="table-light">
                        <tr>
                            <th width="8%">Position</th>
                            <th width="25%">Level</th>
                            <th width="30%">Description</th>
                            <th width="10%">Status</th>
                            <th width="8%">Units</th>
                            <th width="10%">Created</th>
                            <th width="9%">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var level in Model.OrderBy(l => l.Position))
                        {
                            <tr data-level-id="@level.Id">
                                <td>
                                    <div class="d-flex align-items-center">
                                        <span class="badge bg-secondary me-2">#@level.Position</span>
                                       @*  <div class="btn-group-vertical btn-group-sm">
                                            <button class="btn btn-outline-secondary btn-sm position-btn"
                                                    data-level-id="@level.Id"
                                                    data-direction="up"
                                            @(Model.OrderBy(l => l.Position).First().Id == level.Id ? "disabled" : "")>
                                                <i class="fas fa-chevron-up"></i>
                                            </button>
                                            <button class="btn btn-outline-secondary btn-sm position-btn"
                                                    data-level-id="@level.Id"
                                                    data-direction="down"
                                            @(Model.OrderBy(l => l.Position).Last().Id == level.Id ? "disabled" : "")>
                                                <i class="fas fa-chevron-down"></i>
                                            </button>
                                        </div> *@
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(level.PicIcon))
                                        {
                                            <img src="@level.PicIcon" alt="@level.Name" class="rounded me-3" style="width: 40px; height: 40px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-light rounded me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="fas fa-image text-muted"></i>
                                            </div>
                                        }
                                        <div>
                                            <div class="fw-bold">@level.Name</div>
                                            <small class="text-muted">@level.Url</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="text-truncate" style="max-width: 300px;" title="@level.Description">
                                        @level.Description
                                    </div>
                                </td>
                                <td>
                                    <button class="btn btn-sm status-toggle @(level.Status ? "btn-success" : "btn-danger")"
                                            data-level-id="@level.Id"
                                            data-current-status="@level.Status.ToString().ToLower()">
                                        <i class="fas @(level.Status ? "fa-eye" : "fa-eye-slash") me-1"></i>
                                        @(level.Status ? "Active" : "Inactive")
                                    </button>
                                </td>
                                <td>
                                    <span class="badge bg-primary">@level.Units.Count units</span>
                                </td>
                                <td>
                                    <small class="text-muted">@level.CreatedAt.ToString("MM/dd/yyyy")</small>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="@Url.Action("Details", new { id = level.Id })" class="btn btn-outline-info" title="Details">
                                            <i class="fas fa-eye"></i> Details
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = level.Id })" class="btn btn-outline-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                            Edit
                                        </a>
                                      @*   <a href="@Url.Action("Delete", new { id = level.Id })" class="btn btn-outline-danger" title="Delete">
                                            <i class="fas fa-trash"></i>Delete
                                        </a> *@
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Status toggle functionality
            $('.status-toggle').click(function() {
                const button = $(this);
                const levelId = button.data('level-id');
                const currentStatus = button.data('current-status') === 'true';

                $.ajax({
                    url: `/api/LevelsApi/${levelId}/status`,
                    type: 'PATCH',
                    success: function(response) {
                        const newStatus = response.status;
                        button.data('current-status', newStatus);

                        if (newStatus) {
                            button.removeClass('btn-danger').addClass('btn-success');
                            button.html('<i class="fas fa-eye me-1"></i>Active');
                        } else {
                            button.removeClass('btn-success').addClass('btn-danger');
                            button.html('<i class="fas fa-eye-slash me-1"></i>Inactive');
                        }

                        // Update statistics
                        updateStats();
                    },
                    error: function() {
                        alert('Error updating status');
                    }
                });
            });

            // Position change functionality
            $('.position-btn').click(function() {
                const button = $(this);
                const levelId = button.data('level-id');
                const direction = button.data('direction');

                $.ajax({
                    url: `/api/LevelsApi/${levelId}/position`,
                    type: 'PATCH',
                    contentType: 'application/json',
                    data: JSON.stringify({ direction: direction }),
                    success: function() {
                        location.reload(); // Reload to show new positions
                    },
                    error: function() {
                        alert('Error updating position');
                    }
                });
            });

            function updateStats() {
                $.get('/api/LevelsApi/stats', function(stats) {
                    // Update statistics cards if needed
                });
            }
        });
    </script>
}