@model IEnumerable<HorofDashboard.Models.Lesson>

@{
    ViewData["Title"] = "Lesson Management";
    var unitFilter = ViewBag.UnitFilter as HorofDashboard.Models.Unit;
    var levelFilter = ViewBag.LevelFilter as HorofDashboard.Models.Level;
    var units = ViewBag.Units as List<HorofDashboard.Models.Unit>;
    var levels = ViewBag.Levels as List<HorofDashboard.Models.Level>;
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h2 mb-1">Lesson Management</h1>
                    <p class="text-muted mb-0">
                        @if (unitFilter != null)
                        {
                            <span>Managing lessons for: <strong>@unitFilter.Level.Name → @unitFilter.Name</strong></span>
                        }
                        else if (levelFilter != null)
                        {
                            <span>Managing lessons for level: <strong>@levelFilter.Name</strong></span>
                        }
                        else
                        {
                            <span>Manage course lessons and their content</span>
                        }
                    </p>
                </div>
                <div class="d-flex gap-2">
                    @if (unitFilter != null)
                    {
                        <a href="@Url.Action("Create", new { unitId = unitFilter.Id })" class="btn btn-primary">
                            <i class="fas fa-plus me-2"></i>Add Lesson to @unitFilter.Name
                        </a>
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                            <i class="fas fa-list me-2"></i>View All Lessons
                        </a>
                    }
                   @*  else
                    {
                        <a href="@Url.Action("Create")" class="btn btn-primary">
                            <i class="fas fa-plus me-2"></i>Add New Lesson
                        </a>
                    } *@
                </div>
            </div>
        </div>
    </div>

    <!-- Breadcrumb Navigation -->
    @if (unitFilter != null)
    {
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Levels")">Levels</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Details", "Levels", new { id = unitFilter.LevelId })">@unitFilter.Level.Name</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Units", new { levelId = unitFilter.LevelId })">Units</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Details", "Units", new { id = unitFilter.Id })">@unitFilter.Name</a></li>
                <li class="breadcrumb-item active" aria-current="page">Lessons</li>
            </ol>
        </nav>
    }

    <!-- Filters -->
    @if (unitFilter == null && levelFilter == null && units != null && units.Any())
    {
        <div class="card mb-4">
            <div class="card-body">
                <h6 class="card-title mb-3">Filter by Level or Unit</h6>
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="text-muted">By Level:</h6>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <a href="@Url.Action("Index")" class="btn btn-outline-primary btn-sm">All Levels</a>
                            @foreach (var level in levels.GroupBy(l => l.Id).Select(g => g.First()))
                            {
                                var levelLessonCount = Model.Count(l => l.Unit.LevelId == level.Id);
                                <a href="@Url.Action("Index", new { levelId = level.Id })" class="btn btn-outline-secondary btn-sm">
                                    @level.Name
                                    <span class="badge bg-primary ms-1">@levelLessonCount</span>
                                </a>
                            }
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted">By Unit:</h6>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var unit in units.Take(8))
                            {
                                var unitLessonCount = Model.Count(l => l.UnitId == unit.Id);
                                <a href="@Url.Action("Index", new { unitId = unit.Id })" class="btn btn-outline-info btn-sm">
                                    @unit.Name
                                    <span class="badge bg-success ms-1">@unitLessonCount</span>
                                </a>
                            }
                            @if (units.Count > 8)
                            {
                                <small class="text-muted align-self-center">+@(units.Count - 8) more units...</small>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Success/Error Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-2">
            <div class="card border-0 bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h3 class="mb-0">@Model.Count()</h3>
                            <p class="mb-0">Total Lessons</p>
                        </div>
                        <i class="fas fa-play-circle fa-2x opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h3 class="mb-0">@Model.Count(l => l.Status)</h3>
                            <p class="mb-0">Active</p>
                        </div>
                        <i class="fas fa-eye fa-2x opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h3 class="mb-0">@Model.Sum(l => l.Slides.Count)</h3>
                            <p class="mb-0">Total Slides</p>
                        </div>
                        <i class="fas fa-images fa-2x opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 bg-warning text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h3 class="mb-0">@Model.Sum(l => l.MinutesWork ?? 0)</h3>
                            <p class="mb-0">Total Minutes</p>
                        </div>
                        <i class="fas fa-clock fa-2x opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 bg-danger text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h3 class="mb-0">@(Model.Any() ? Math.Round(Model.Average(l => l.MinutesWork ?? 0), 1) : 0)</h3>
                            <p class="mb-0">Avg Minutes</p>
                        </div>
                        <i class="fas fa-stopwatch fa-2x opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 bg-secondary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h3 class="mb-0">@(Model.Any() ? Math.Round(Model.Average(l => l.Slides.Count), 1) : 0)</h3>
                            <p class="mb-0">Avg Slides</p>
                        </div>
                        <i class="fas fa-chart-bar fa-2x opacity-75"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Lessons Table -->
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover" id="lessonsTable">
                    <thead class="table-light">
                        <tr>
                            <th width="8%">Position</th>
                            <th width="20%">Lesson</th>
                            <th width="15%">Unit/Level</th>
                            <th width="20%">Description</th>
                            <th width="8%">Status</th>
                            <th width="10%">Content</th>
                            <th width="8%">Duration</th>
                            <th width="6%">Created</th>
                            <th width="5%">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var unitGroup in Model.GroupBy(l => l.Unit).OrderBy(g => g.Key.Level.Position).ThenBy(g => g.Key.Position))
                        {
                            @foreach (var lesson in unitGroup.OrderBy(l => l.Position))
                            {
                                <tr data-lesson-id="@lesson.Id" data-unit-id="@lesson.UnitId">
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <span class="badge bg-secondary me-2">#@lesson.Position</span>
                                           @*  <div class="btn-group-vertical btn-group-sm">
                                                <button class="btn btn-outline-secondary btn-sm position-btn"
                                                        data-lesson-id="@lesson.Id"
                                                        data-direction="up"
                                                @(unitGroup.OrderBy(l => l.Position).First().Id == lesson.Id ? "disabled" : "")>
                                                    <i class="fas fa-chevron-up"></i>
                                                </button>
                                                <button class="btn btn-outline-secondary btn-sm position-btn"
                                                        data-lesson-id="@lesson.Id"
                                                        data-direction="down"
                                                @(unitGroup.OrderBy(l => l.Position).Last().Id == lesson.Id ? "disabled" : "")>
                                                    <i class="fas fa-chevron-down"></i>
                                                </button>
                                            </div> *@
                                        </div>
                                    </td>
                                    <td>
                                        <div>
                                            <div class="fw-bold">@lesson.Name</div>
                                            <small class="text-muted">@lesson.Url</small>
                                        </div>
                                    </td>
                                    <td>
                                        <div>
                                            <span class="badge bg-info mb-1">@lesson.Unit.Level.Name</span><br>
                                            <span class="badge bg-secondary">@lesson.Unit.Name</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="text-truncate" style="max-width: 200px;" title="@lesson.Description">
                                            @lesson.Description
                                        </div>
                                        @if (!string.IsNullOrEmpty(lesson.Details))
                                        {
                                            <small class="text-muted d-block">Has detailed content</small>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm status-toggle @(lesson.Status ? "btn-success" : "btn-danger")"
                                                data-lesson-id="@lesson.Id"
                                                data-current-status="@lesson.Status.ToString().ToLower()">
                                            <i class="fas @(lesson.Status ? "fa-eye" : "fa-eye-slash") me-1"></i>
                                            @(lesson.Status ? "Active" : "Inactive")
                                        </button>
                                    </td>
                                    <td>
                                        <div class="text-center">
                                            <div class="small">
                                                <strong>@lesson.Slides.Count</strong> slides
                                            </div>
                                            @if (lesson.Slides.Any())
                                            {
                                                <div class="progress" style="height: 4px;">
                                                    <div class="progress-bar bg-success" style="width: 100%"></div>
                                                </div>
                                                <small class="text-success">Complete</small>
                                            }
                                            else
                                            {
                                                <small class="text-muted">No slides</small>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @if (lesson.MinutesWork.HasValue)
                                        {
                                            <span class="badge bg-warning text-dark">@lesson.MinutesWork min</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted">@lesson.CreatedAt.ToString("MM/dd")</small>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="@Url.Action("Details", new { id = lesson.Id })" class="btn btn-outline-info" title="Details">
                                                <i class="fas fa-eye"></i>Details
                                            </a>
                                            <a href="@Url.Action("Edit", new { id = lesson.Id })" class="btn btn-outline-warning" title="Edit">
                                                <i class="fas fa-edit"></i>Edit
                                            </a>
                                            <a href="@Url.Action("Delete", new { id = lesson.Id })" class="btn btn-outline-danger" title="Delete">
                                                <i class="fas fa-trash"></i>Delete
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Status toggle functionality
            $('.status-toggle').click(function() {
                const button = $(this);
                const lessonId = button.data('lesson-id');

                $.ajax({
                    url: `/api/LessonsApi/${lessonId}/status`,
                    type: 'PATCH',
                    success: function(response) {
                        const newStatus = response.status;
                        button.data('current-status', newStatus);

                        if (newStatus) {
                            button.removeClass('btn-danger').addClass('btn-success');
                            button.html('<i class="fas fa-eye me-1"></i>Active');
                        } else {
                            button.removeClass('btn-success').addClass('btn-danger');
                            button.html('<i class="fas fa-eye-slash me-1"></i>Inactive');
                        }
                    },
                    error: function() {
                        alert('Error updating status');
                    }
                });
            });

            // Position change functionality
            $('.position-btn').click(function() {
                const button = $(this);
                const lessonId = button.data('lesson-id');
                const direction = button.data('direction');

                $.ajax({
                    url: `/api/LessonsApi/${lessonId}/position`,
                    type: 'PATCH',
                    contentType: 'application/json',
                    data: JSON.stringify({ direction: direction }),
                    success: function() {
                        location.reload(); // Reload to show new positions
                    },
                    error: function() {
                        alert('Error updating position');
                    }
                });
            });
        });
    </script>
}
