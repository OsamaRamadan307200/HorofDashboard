@model HorofDashboard.ViewModels.LessonCreateViewModel

@{
    ViewData["Title"] = "Create Lesson";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">Create New Lesson</h4>
                        <a href="@Url.Action("Index", new { unitId = Model.UnitId })" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Back to Lessons
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <div>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                        <div class="row">
                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label">Lesson Name *</label>
                                    <input asp-for="Name" class="form-control" placeholder="Enter lesson name" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="UnitId" class="form-label">Unit *</label>
                                    <select asp-for="UnitId" asp-items="ViewBag.Units" class="form-select">
                                        <option value="">Select a unit</option>
                                    </select>
                                    <span asp-validation-for="UnitId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Url" class="form-label">URL *</label>
                            <input asp-for="Url" class="form-control" placeholder="/lessons/lesson-name" />
                            <span asp-validation-for="Url" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Brief description of the lesson"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Details" class="form-label">Detailed Content</label>
                            <textarea asp-for="Details" class="form-control" rows="6" placeholder="Detailed lesson content, learning objectives, notes, etc."></textarea>
                            <span asp-validation-for="Details" class="text-danger"></span>
                            <div class="form-text">Optional: Add comprehensive lesson details, learning objectives, notes</div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="Position" class="form-label">Position</label>
                                    <input asp-for="Position" class="form-control" type="number" min="1" />
                                    <span asp-validation-for="Position" class="text-danger"></span>
                                    <div class="form-text">Leave empty to auto-assign</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="MinutesWork" class="form-label">Duration (Minutes)</label>
                                    <input asp-for="MinutesWork" class="form-control" type="number" min="0" />
                                    <span asp-validation-for="MinutesWork" class="text-danger"></span>
                                    <div class="form-text">Estimated lesson duration</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <div class="form-check mt-4">
                                        <input asp-for="Status" class="form-check-input" type="checkbox" />
                                        <label asp-for="Status" class="form-check-label">Active Status</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 pt-3">
                            <button onclick="submitForm()" class="btn btn-success">
                                <i class="fas fa-save me-2"></i>Create Lesson
                            </button>
                            <a href="@Url.Action("Index", new { unitId = Model.UnitId })" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function submitForm() {
            const form = $('<form>', {
                'method': 'POST',
                'action': '@Url.Action("Create")'
            });

            // Add anti-forgery token
            form.append($('@Html.AntiForgeryToken()'));

            // Add all form fields
            $('input, select, textarea').each(function() {
                if ($(this).attr('name')) {
                    const input = $('<input>', {
                        'type': 'hidden',
                        'name': $(this).attr('name'),
                        'value': $(this).is(':checkbox') ? $(this).is(':checked') : $(this).val()
                    });
                    form.append(input);
                }
            });

            $('body').append(form);
            form.submit();
        }
    </script>
}