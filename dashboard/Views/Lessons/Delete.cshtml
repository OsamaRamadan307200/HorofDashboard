@model HorofDashboard.Models.Lesson

@{
    ViewData["Title"] = "Delete Lesson";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-exclamation-triangle me-2"></i>Delete Lesson
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <strong>Warning!</strong> Are you sure you want to delete this lesson? This action cannot be undone.
                    </div>

                    <div class="text-center mb-4">
                        <h5>@Model.Name</h5>
                        <div class="mb-2">
                            <span class="badge bg-info fs-6 me-2">Level: @Model.Unit.Level.Name</span>
                            <span class="badge bg-secondary fs-6">Unit: @Model.Unit.Name</span>
                        </div>
                        <p class="text-muted">@Model.Description</p>
                    </div>

                    <div class="row text-center mb-4">
                        <div class="col-3">
                            <div class="card bg-light">
                                <div class="card-body py-2">
                                    <div class="h5 mb-0">@Model.Position</div>
                                    <small class="text-muted">Position</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="card bg-light">
                                <div class="card-body py-2">
                                    <div class="h5 mb-0">@Model.Slides.Count</div>
                                    <small class="text-muted">Slides</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="card bg-light">
                                <div class="card-body py-2">
                                    <div class="h5 mb-0">@(Model.MinutesWork ?? 0)</div>
                                    <small class="text-muted">Minutes</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="card bg-light">
                                <div class="card-body py-2">
                                    <div class="h5 mb-0">
                                        <span class="badge @(Model.Status ? "bg-success" : "bg-secondary")">
                                            @(Model.Status ? "Active" : "Inactive")
                                        </span>
                                    </div>
                                    <small class="text-muted">Status</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (Model.Slides.Any())
                    {
                        <div class="alert alert-danger">
                            <strong>Important:</strong> This lesson has @Model.Slides.Count associated slide(s).
                            Deleting this lesson will also delete these slides.
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Details))
                    {
                        <div class="alert alert-info">
                            <strong>Note:</strong> This lesson contains detailed content that will be permanently lost.
                        </div>
                    }

                    <div>
                        <input asp-for="Id" type="hidden" />
                        <div class="d-flex gap-2 justify-content-center">
                            <button onclick="deleteLesson()" class="btn btn-danger">
                                <i class="fas fa-trash me-2"></i>Yes, Delete Lesson
                            </button>
                            <a href="@Url.Action("Index", new { unitId = Model.UnitId })" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteLesson() {
            const form = $('<form>', {
                'method': 'POST',
                'action': '@Url.Action("Delete", new { id = Model.Id })'
            });

            // Add anti-forgery token
            form.append($('@Html.AntiForgeryToken()'));

            // Add ID
            form.append($('<input>', {
                'type': 'hidden',
                'name': 'Id',
                'value': '@Model.Id'
            }));

            $('body').append(form);
            form.submit();
        }
    </script>
}