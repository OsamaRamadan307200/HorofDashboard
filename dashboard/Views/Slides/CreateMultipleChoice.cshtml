@model HorofDashboard.ViewModels.Slides.MultipleChoiceViewModel
@{
    ViewData["Title"]         = "Create Multiple Choice Slide";
    ViewData["SlideTypeName"] = "Multiple Choice";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm">

                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <h4 class="mb-0">
                        <i class="fas fa-list-ul me-2 text-primary"></i>Multiple Choice
                    </h4>
                    <div class="d-flex gap-2">
                        <a href="@Url.Action("SelectType", new { lessonId = Model.LessonId })"
                           class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-exchange-alt me-1"></i>Change Type
                        </a>
                        <a href="@Url.Action("Index", new { lessonId = Model.LessonId })"
                           class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-arrow-left me-1"></i>Back
                        </a>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="CreateMultipleChoice" method="post" id="mcForm">
                        @Html.AntiForgeryToken()

                        <partial name="_SlideBaseFields" model="Model" />

                        <hr class="my-4" />

                        <h5 class="mb-1">Answer Choices</h5>
                        <p class="text-muted small mb-3">Add at least 2 choices and mark the correct one.</p>

                        <div id="choicesList" class="mb-2"></div>

                        <button type="button" class="btn btn-outline-primary btn-sm mb-3" id="addChoice">
                            <i class="fas fa-plus me-1"></i>Add Choice
                        </button>

                        <div class="d-flex gap-2 pt-2 border-top mt-3">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="fas fa-save me-2"></i>Create Slide
                            </button>
                            <a href="@Url.Action("Index", new { lessonId = Model.LessonId })"
                               class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function addChoice(text = '', isCorrect = false) {
            const list  = document.getElementById('choicesList');
            const idx   = list.querySelectorAll('.choice-item').length;
            const num   = idx + 1;

            list.insertAdjacentHTML('beforeend', `
                <div class="choice-item row align-items-center mb-2 g-2">
                    <div class="col-md-7">
                        <div class="input-group">
                            <span class="input-group-text text-muted">${num}</span>
                            <input type="text" class="form-control choice-text"
                                   name="Choices[${idx}]"
                                   placeholder="Enter choice ${num}"
                                   value="${escHtml(text)}" required />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-check ms-2">
                            <input type="radio" name="CorrectChoiceIndex"
                                   class="form-check-input"
                                   value="${num}" ${isCorrect ? 'checked' : ''} required />
                            <label class="form-check-label text-success fw-semibold">Correct answer</label>
                        </div>
                    </div>
                    <div class="col-md-2 text-end">
                        <button type="button" class="btn btn-outline-danger btn-sm remove-choice">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </div>
                </div>`);
        }

        function reindex() {
            document.querySelectorAll('#choicesList .choice-item').forEach((el, i) => {
                const num = i + 1;
                el.querySelector('.input-group-text').textContent   = num;
                el.querySelector('.choice-text').name              = `Choices[${i}]`;
                el.querySelector('.choice-text').placeholder       = `Enter choice ${num}`;
                el.querySelector('input[type="radio"]').value      = num;
            });
        }

        function escHtml(s) {
            return s.replace(/[&<>"']/g, c =>
                ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
        }

        document.getElementById('addChoice').addEventListener('click', () => addChoice());

        document.getElementById('choicesList').addEventListener('click', e => {
            if (!e.target.closest('.remove-choice')) return;
            const items = document.querySelectorAll('#choicesList .choice-item');
            if (items.length <= 2) {
                alert('You need at least 2 choices.');
                return;
            }
            e.target.closest('.choice-item').remove();
            reindex();
        });

        // Seed with 4 blank choices
        addChoice(); addChoice(); addChoice(); addChoice();
    </script>
}
