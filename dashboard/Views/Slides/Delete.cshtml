@model HorofDashboard.Models.Slide

@{
    ViewData["Title"] = "Delete Slide";
}

<div class="container-fluid py-4 px-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="card" style="border:1px solid #fca5a5;">
                <div class="card-header text-white" style="background:#ef4444;">
                    <h5 class="mb-0"><i class="fas fa-exclamation-triangle me-2"></i>Delete Slide</h5>
                </div>
                <div class="card-body">

                    <div class="alert alert-danger">
                        <i class="fas fa-warning me-2"></i>
                        Are you sure you want to permanently delete this slide? This action <strong>cannot be undone</strong>.
                    </div>

                    <div class="card bg-light mb-4">
                        <div class="card-body py-3">
                            <dl class="row mb-0" style="font-size:13.5px;">
                                <dt class="col-5 fw-semibold">Slide Name</dt>
                                <dd class="col-7">@Model.Name</dd>

                                <dt class="col-5 fw-semibold">Type</dt>
                                <dd class="col-7">
                                    <span class="badge bg-secondary">@(Model.MasterSlideType?.Name ?? "Unknown")</span>
                                </dd>

                                <dt class="col-5 fw-semibold">Lesson</dt>
                                <dd class="col-7">@(Model.Lesson?.Name ?? "—")</dd>

                                <dt class="col-5 fw-semibold">Position</dt>
                                <dd class="col-7">#@Model.Position</dd>

                                <dt class="col-5 fw-semibold">Points</dt>
                                <dd class="col-7">@(Model.Points ?? 0) pts</dd>

                                <dt class="col-5 fw-semibold">Status</dt>
                                <dd class="col-7">
                                    <span class="badge @(Model.Status ? "bg-success" : "bg-secondary")">
                                        @(Model.Status ? "Active" : "Inactive")
                                    </span>
                                </dd>
                            </dl>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash me-2"></i>Yes, Delete Slide
                            </button>
                            <a href="@Url.Action("Index", new { lessonId = Model.LessonId })" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Cancel
                            </a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>
