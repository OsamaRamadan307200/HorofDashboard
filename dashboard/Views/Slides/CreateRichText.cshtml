@model HorofDashboard.ViewModels.Slides.RichTextViewModel
@{
    ViewData["Title"]         = "Create Rich Text Slide";
    ViewData["SlideTypeName"] = "Rich Text";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm">

                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <h4 class="mb-0">
                        <i class="fas fa-align-left me-2 text-primary"></i>Rich Text
                    </h4>
                    <div class="d-flex gap-2">
                        <a href="@Url.Action("SelectType", new { lessonId = Model.LessonId })"
                           class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-exchange-alt me-1"></i>Change Type
                        </a>
                        <a href="@Url.Action("Index", new { lessonId = Model.LessonId })"
                           class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-arrow-left me-1"></i>Back
                        </a>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="CreateRichText" method="post" id="rtForm">
                        @Html.AntiForgeryToken()

                        <partial name="_SlideBaseFields" model="Model" />

                        <hr class="my-4" />

                        <h5 class="mb-1">Expected Answer</h5>
                        <p class="text-muted small mb-3">
                            Use the editor below to write the expected answer with full formatting support.
                        </p>

                        <div class="mb-3">
                            <div id="quillEditor"
                                 style="min-height:220px; border:1px solid #ced4da; border-top:none; border-radius:0 0 .375rem .375rem;"></div>
                            <input type="hidden" asp-for="WriteWordAnswer" id="rtHidden" />
                            <span asp-validation-for="WriteWordAnswer" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 pt-2 border-top mt-3">
                            <button type="submit" class="btn btn-success px-4" id="rtSubmit">
                                <i class="fas fa-save me-2"></i>Create Slide
                            </button>
                            <a href="@Url.Action("Index", new { lessonId = Model.LessonId })"
                               class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <link href="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.snow.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.min.js"></script>
    <script>
        const quill = new Quill('#quillEditor', {
            theme: 'snow',
            placeholder: 'Enter the expected answer with formatting...',
            modules: {
                toolbar: [
                    [{ header: [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ list: 'ordered' }, { list: 'bullet' }],
                    [{ size: ['small', false, 'large', 'huge'] }],
                    [{ align: [] }],
                    [{ color: [] }, { background: [] }],
                    ['link'], ['clean']
                ]
            }
        });

        document.getElementById('rtForm').addEventListener('submit', function () {
            const content = quill.root.innerHTML.trim();
            if (content === '<p><br></p>' || content === '') {
                document.getElementById('rtHidden').value = '';
            } else {
                document.getElementById('rtHidden').value = content;
            }
        });
    </script>
}
